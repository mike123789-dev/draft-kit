{
  "name": "@draftkit/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'skip lint for core'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "find src -name '*.js' -delete; find src -name '*.d.ts' -delete",
    "test": "vitest run"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
