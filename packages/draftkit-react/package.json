{
  "name": "@draftkit/react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'skip lint for react package'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "find src -name '*.js' -delete; find src -name '*.d.ts' -delete",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@draftkit/core": "workspace:*",
    "react-live": "^4.1.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
